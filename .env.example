# LiMeiHua Taproot All Bridge - Environment Variables

# ============ Ethereum Configuration ============
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
PRIVATE_KEY=your_private_key_here
BRIDGE_CONTRACT_ADDRESS=0x...
BRIDGE_CONTRACT_ABI=[]

# ============ Bitcoin Configuration ============
BITCOIN_RPC_URL=http://localhost:8080
BITCOIN_USERNAME=user
BITCOIN_PASSWORD=password

# ============ Server Configuration ============
PORT=3000
NODE_ENV=development

# ============ Frontend Configuration ============
REACT_APP_API_URL=http://localhost:3000

# ============ Relayer Configuration ============
RELAYER_ENABLED=true
RELAYER_CHECK_INTERVAL=10000

# ============ Database Configuration ============
DATABASE_URL=postgresql://user:password@localhost:5432/bridge

# ============ Logging ============
LOG_LEVEL=info
